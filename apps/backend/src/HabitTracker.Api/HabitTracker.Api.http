@HabitTracker.Api_HostAddress = http://localhost:5137

### List the current user's habits (ordered by Position)
GET {{HabitTracker.Api_HostAddress}}/api/habits
Accept: application/json

### Create a habit
# @name createHabit
POST {{HabitTracker.Api_HostAddress}}/api/habits
Content-Type: application/json

{
  "name": "Read",
  "polarity": "Positive"
}

### Get a single habit (paste an id from a create/list response)
GET {{HabitTracker.Api_HostAddress}}/api/habits/{{createHabit.response.body.$.id}}
Accept: application/json

### Update a habit
PUT {{HabitTracker.Api_HostAddress}}/api/habits/{{createHabit.response.body.$.id}}
Content-Type: application/json

{
  "name": "Read more",
  "polarity": "Positive",
  "position": 0
}

### Delete a habit
DELETE {{HabitTracker.Api_HostAddress}}/api/habits/{{createHabit.response.body.$.id}}

### Sync: merge the client's roster + month(s) and get the authoritative alive state back.
# Timestamps are epoch milliseconds UTC; `deleted: true` rows are tombstones (ADR 0003).
POST {{HabitTracker.Api_HostAddress}}/api/sync
Content-Type: application/json

{
  "habits": [
    {
      "id": "11111111-1111-1111-1111-111111111111",
      "name": "Read",
      "polarity": "Positive",
      "position": 0,
      "updatedAt": 1750680000000,
      "deleted": false
    }
  ],
  "months": [
    {
      "month": "2026-06",
      "entries": [
        {
          "habitId": "11111111-1111-1111-1111-111111111111",
          "date": "2026-06-03",
          "outcome": "Success",
          "updatedAt": 1750680001000,
          "deleted": false
        }
      ]
    }
  ]
}
