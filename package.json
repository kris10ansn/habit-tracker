{
    "name": "habit-tracker",
    "private": true,
    "packageManager": "pnpm@10.33.4",
    "scripts": {
        "format": "prettier --write . && pnpm -r run format",
        "lint": "pnpm -r run lint",
        "typecheck": "pnpm -r run typecheck",
        "mobile:start": "pnpm --filter @habit-tracker/mobile run start",
        "mobile:android": "pnpm --filter @habit-tracker/mobile run android",
        "mobile:ios": "pnpm --filter @habit-tracker/mobile run ios",
        "mobile:web": "pnpm --filter @habit-tracker/mobile run web",
        "remarkable:build": "pnpm --filter @habit-tracker/remarkable run build",
        "remarkable:clean": "pnpm --filter @habit-tracker/remarkable run clean",
        "remarkable:deploy": "pnpm --filter @habit-tracker/remarkable run deploy",
        "remarkable:remove": "pnpm --filter @habit-tracker/remarkable run remove",
        "backend:build": "pnpm --filter @habit-tracker/backend run build",
        "backend:start": "pnpm --filter @habit-tracker/backend run start",
        "backend:test": "pnpm --filter @habit-tracker/backend run test",
        "backend:migrate": "pnpm --filter @habit-tracker/backend run migrate",
        "backend:db:up": "pnpm --filter @habit-tracker/backend run db:up",
        "backend:db:down": "pnpm --filter @habit-tracker/backend run db:down"
    },
    "devDependencies": {
        "prettier": "^3.8.3"
    }
}
